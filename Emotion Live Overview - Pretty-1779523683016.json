        {
          "datasource": {
            "type": "influxdb",
            "uid": "afgyjaeh9mubke"
          },
          "query": "import \"array\"\nbase =\n  from(bucket: \"${bucket}\")\n    |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n    |> filter(fn: (r) => r._measurement == \"emotion_metrics\")\n    |> filter(fn: (r) => r.source == \"${source}\" and r.camera_index == \"${camera_index}\")\n    |> filter(fn: (r) => r._field == \"happy\" or r._field == \"sad\" or r._field == \"angry\" or r._field == \"neutral\")\n    |> last()\n    |> keep(columns: [\"_field\", \"_value\"])\n\nhappy = base |> filter(fn: (r) => r._field == \"happy\") |> findRecord(fn: (key) => true, idx: 0)\nsad = base |> filter(fn: (r) => r._field == \"sad\") |> findRecord(fn: (key) => true, idx: 0)\nangry = base |> filter(fn: (r) => r._field == \"angry\") |> findRecord(fn: (key) => true, idx: 0)\nneutral = base |> filter(fn: (r) => r._field == \"neutral\") |> findRecord(fn: (key) => true, idx: 0)\n\nmaxv = if happy._value >= sad._value and happy._value >= angry._value and happy._value >= neutral._value then happy._value\n  else if sad._value >= angry._value and sad._value >= neutral._value then sad._value\n  else if angry._value >= neutral._value then angry._value\n  else neutral._value\n\narray.from(rows: [{_time: now(), _value: maxv}])",
          "refId": "A"
        }
      ],
      "title": "最高分數",
      "type": "gauge"
    },
